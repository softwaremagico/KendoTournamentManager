{
  "name": "frontend",
  "version": "3.5.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run prepare:translations && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prepare:translations": "npm run clean:translations && mkdir -p src/assets/i18n/wizardry-theme && cp -R ./node_modules/@biit-solutions/wizardry-theme/assets/i18n/. src/assets/i18n/wizardry-theme/",
    "clean:translations": "rm -rf src/assets/i18n/wizardry-theme/"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/cdk": "21.2.13",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/material": "21.2.13",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "@biit-solutions/biit-icons-collection": "latest",
    "@biit-solutions/wizardry-theme": "latest",
    "@jsverse/transloco": "^8.4.0",
    "@jsverse/transloco-locale": "^8.4.0",
    "@stomp/rx-stomp": "^2.0.0",
    "dom-to-image": "^2.6.0",
    "jspdf": "^4.2.1",
    "ngx-cookie-service": "21.3.1",
    "ngx-webcam": "^0.4.1",
