    "@angular-devkit/build-angular": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@types/dom-to-image": "^2.6.4",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^18.17.17",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
