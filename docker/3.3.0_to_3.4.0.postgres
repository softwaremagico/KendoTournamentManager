alter table tournaments
    modify tournament_type enum ('BUBBLE_SORT', 'CHAMPIONSHIP', 'CUSTOMIZED', 'CUSTOM_CHAMPIONSHIP', 'KING_OF_THE_MOUNTAIN', 'LEAGUE', 'LOOP', 'SENBATSU', 'TREE', 'SWISS') not null;

alter table tournament_extra_properties
    modify property_key enum ('AVOID_DUPLICATES', 'DIPLOMA_NAME_HEIGHT', 'KING_DRAW_RESOLUTION', 'KING_INDEX', 'LEAGUE_FIGHTS_ORDER_GENERATION', 'MAXIMIZE_FIGHTS', 'NUMBER_OF_WINNERS', 'ODD_FIGHTS_RESOLVED_ASAP', 'SENBATSU_CHALLENGE_DISTANCE', 'SWISS_ROUNDS', 'SWISS_TIE_BREAK_RULE', 'SWISS_AVOID_REPEATED_PAIRINGS') not null;

